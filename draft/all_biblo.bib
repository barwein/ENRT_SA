@Article{Simmons2015,
  author   = {Simmons, Nicole and Donnell, Deborah and Ou, San-san and Celentano, David D. and Aramrattana, Apinun and Davis-Vogel, Annet and Metzger, David and Latkin, Carl},
  journal  = {AIDS and Behavior},
  title    = {Assessment of {Contamination} and {Misclassification} {Biases} in a {Randomized} {Controlled} {Trial} of a {Social} {Network} {Peer} {Education} {Intervention} to {Reduce} {HIV} risk {Behaviors} {Among} {Drug} {Users} and {Risk} {Partners} in {Philadelphia}, {PA} and {Chiang} {Mai}, {Thailand}},
  year     = {2015},
  issn     = {1573-3254},
  month    = oct,
  number   = {10},
  pages    = {1818--1827},
  volume   = {19},
  abstract = {Controlled trials of HIV prevention and care interventions are susceptible to contamination. In a randomized controlled trial of a social network peer education intervention among people who inject drugs and their risk partners in Philadelphia, PA and Chiang Mai, Thailand, we tested a contamination measure based on recall of intervention terms. We assessed the recall of test, negative and positive control terms among intervention and control arm participants and compared the relative odds of recall of test versus negative control terms between study arms. The contamination measures showed good discriminant ability among participants in Chiang Mai. In Philadelphia there was no evidence of contamination and little evidence of diffusion. In Chiang Mai there was strong evidence of diffusion and contamination. Network structure and peer education in Chiang Mai likely led to contamination. Recall of intervention materials can be a useful method to detect contamination in experimental interventions.},
  annote   = {Assessment of contamination in the HPTN 037 study!},
  doi      = {10.1007/s10461-015-1073-3},
  file     = {Full Text PDF:C\:\\Users\\bar21\\Zotero\\storage\\AQVC9CVM\\Simmons et al. - 2015 - Assessment of Contamination and Misclassification .pdf:application/pdf},
  groups   = {Applied network experiments},
  keywords = {Contamination, HIV, Prevention, Social networks, Diffusion, Injection drug use},
  language = {en},
  url      = {https://doi.org/10.1007/s10461-015-1073-3},
  urldate  = {2023-07-16},
}

