@Article{Krivitsky2017,
  author   = {Krivitsky, Pavel N. and Morris, Martina},
  journal  = {The Annals of Applied Statistics},
  title    = {Inference for social network models from egocentrically sampled data, with application to understanding persistent racial disparities in {HIV} prevalence in the {US}},
  year     = {2017},
  issn     = {1932-6157, 1941-7330},
  month    = mar,
  note     = {Publisher: Institute of Mathematical Statistics},
  number   = {1},
  pages    = {427--455},
  volume   = {11},
  abstract = {Egocentric network sampling observes the network of interest from the point of view of a set of sampled actors, who provide information about themselves and anonymized information on their network neighbors. In survey research, this is often the most practical, and sometimes the only, way to observe certain classes of networks, with the sexual networks that underlie HIV transmission being the archetypal case. Although methods exist for recovering some descriptive network features, there is no rigorous and practical statistical foundation for estimation and inference for network models from such data. We identify a subclass of exponential-family random graph models (ERGMs) amenable to being estimated from egocentrically sampled network data, and apply pseudo-maximum-likelihood estimation to do so and to rigorously quantify the uncertainty of the estimates. For ERGMs parametrized to be invariant to network size, we describe a computationally tractable approach to this problem. We use this methodology to help understand persistent racial disparities in HIV prevalence in the US. We also discuss some extensions, including how our framework may be applied to triadic effects when data about ties among the respondent’s neighbors are also collected.},
  annote   = {Nice extension of ERGM for egocentric data. They consider ``minimal” egocentric design in which each node has its neighbors attributes and nodes (=egos) are randomly sampled (along with their alters attributes). Key finding is that ERGM that can be estimated from egocentric data are more limited than general ERGM (requires specific family of statistics). They did considered the sampling weights but seek to estimate general network parameters (or population level parameters) using the egocentric sample. In a way, this is network reconstruction from sampled data in a model-based settings.},
  doi      = {10.1214/16-AOAS1010},
  file     = {Full Text PDF:C\:\\Users\\bar21\\Zotero\\storage\\5XQYZJYB\\Krivitsky and Morris - 2017 - Inference for social network models from egocentri.pdf:application/pdf},
  keywords = {Social network, egocentrically sampled data, ERGM, pseudo maximum likelihood, pseudolikelihood, random graph},
  url      = {https://projecteuclid.org/journals/annals-of-applied-statistics/volume-11/issue-1/Inference-for-social-network-models-from-egocentrically-sampled-data-with/10.1214/16-AOAS1010.full},
  urldate  = {2023-06-12},
}

@Book{Perry2018,
  author     = {Perry, Brea L. and Pescosolido, Bernice A. and Borgatti, Stephen P.},
  publisher  = {Cambridge University Press},
  title      = {Egocentric {Network} {Analysis}: {Foundations}, {Methods}, and {Models}},
  year       = {2018},
  address    = {Cambridge},
  isbn       = {978-1-107-13143-9},
  series     = {Structural {Analysis} in the {Social} {Sciences}},
  abstract   = {Egocentric network analysis is used widely across the social sciences, especially in anthropology, political science, economics, and sociology, and is increasingly being employed in communications, informatics, and business and marketing studies. Egocentric network analysis requires a unique set of data collection and analysis skills that overlap only minimally with other network methodologies. However, until now there has been no single reference for conceptualizing, collecting, and analyzing egocentric social network data. This comprehensive guide to study design, data collection, and analysis brings together the state of knowledge with the most effective research tools to guide newcomers to this field. It is illustrated with many engaging examples and graphics and assumes no prior knowledge. Covering the entire research process in a logical sequence, from conceptualizing research questions to interpreting findings, this volume provides a solid foundation for researchers at any stage of their career to learn and apply ego network methods.},
  annote     = {General reading notes. egocentric networks are very easy to acquire in comparison to sociocentric networks. They typically modeled as ego-alters clusters. Gathering accurate information from sampled egos (e.g., alters nominations, alters information, alter-alter ties), is often very difficult and might be inaccurate. The authors suggest different techniques for improve accuracy. Separate the ego and alter levels analysis. That is, egos are “level 2” whereas alters are “level 1”. That means that ego-networks yield an “induced” clusters. They recommend to model the ego-level regression using typical OLS, but the level-2 (alters) level using multi level model (aka mixed models). “The cross-classified model.” (Perry et al., 2018, p. 263) Key section to read. When alters are member of several ego-networks, they suggest to add random intercept for each ego-network (i.e., not a hierarchical model anymore). That is plausible when there is information about this “crossover” of alters, but not when alters are “taken out of the pool” when some ego selected them? moreover, they discuss only statistical error (correlation between residuals) and not causal violations, i.e., the effects are not longer have the same meaning. “However, despite this turnover in the individuals that make up a network, the structure and composition of ego networks (e.g., density, percent kin) tend to remain fairly stable over time (Lubbers et al. 2010; Wellman et al. 1997).” (Perry et al., 2018, p. 283). Specifically, the core/periphery structure implies that the core (alters) is more persistent than the periphery (higher order), thus motivate the use of dynamic ego-network analysis (more than sociocentric one). “This structure is strongly related to dynamic patterns in egocentric networks such that the core tends to remain stable over time, while the periphery is characterized by a fair amount of instability and membership turnover (Morgan et al. 1997)” (Perry et al., 2018, p. 283). “In an egocentric design, the ego is the respondent, and all of the information about the alters and their ties to other alters is obtained from ego. In a whole network or sociocentric design, every node is a respondent, and information about the alter-alter ties is obtained from the alters themselves.” (Perry et al., 2018, p. 319) “table 10.1 Typology of studies based on ego network vs sociocentric data or analysis” (Perry et al., 2018, p. 320) “Merging Ego Networks to Form a Sociocentric Network” (Perry et al., 2018, p. 320) discuss merging information from egos respondenats to obtain one whole network (“connecting the dots”). Discuss measurement stuff and not a network probabilistic model for the task (such exist).},
  doi        = {10.1017/9781316443255},
  file       = {Perry et al. - 2018 - Egocentric Network Analysis Foundations, Methods,.pdf:C\:\\Users\\bar21\\Zotero\\storage\\35VA6BGH\\Perry et al. - 2018 - Egocentric Network Analysis Foundations, Methods,.pdf:application/pdf;Snapshot:C\:\\Users\\bar21\\Zotero\\storage\\MNL2MC7Q\\D241B6D07F1A5C760657F252FAD65A4C.html:text/html},
  shorttitle = {Egocentric {Network} {Analysis}},
  url        = {https://www.cambridge.org/core/books/egocentric-network-analysis/D241B6D07F1A5C760657F252FAD65A4C},
  urldate    = {2023-06-12},
}

@Article{Sewell2017,
  author   = {Sewell, Daniel K.},
  journal  = {Social Networks},
  title    = {Network autocorrelation models with egocentric data},
  year     = {2017},
  issn     = {0378-8733},
  month    = may,
  pages    = {113--123},
  volume   = {49},
  abstract = {Network autocorrelation models have been widely used for decades to model the joint distribution of the attributes of a network's actors. This class of models can estimate both the effect of individual characteristics as well as the network effect, or social influence, on some actor attribute of interest. Collecting data on the entire network, however, is very often infeasible or impossible if the network boundary is unknown or difficult to define. Obtaining egocentric network data overcomes these obstacles, but as of yet there has been no clear way to model this type of data and still appropriately capture the network effect on the actor attributes in a way that is compatible with a joint distribution on the full network data. This paper adapts the class of network autocorrelation models to handle egocentric data. The proposed methods thus incorporate the complex dependence structure of the data induced by the network rather than simply using ad hoc measures of the egos’ networks to model the mean structure, and can estimate the network effect on the actor attribute of interest. The vast quantities of unknown information about the network can be succinctly represented in such a way that only depends on the number of alters in the egocentric network data and not on the total number of actors in the network. Estimation is done within a Bayesian framework. A simulation study is performed to evaluate the estimation performance, and an egocentric data set is analyzed where the aim is to determine if there is a network effect on environmental mastery, an important aspect of psychological well-being.},
  annote   = {Considered network that are derived from egocentric sampling (``star sampling”), i.e., egos are randomly sampled and all the alters of each egos are sampled as well. They consider network auto regression linear model and suggested bayesian procedure that account for the missing data (missing social influence between alters and non-sampled units). Their suggestion does not account for the sampling procedure itself and heavily relies on the parametric assumptions made. Nevertheless, their structural assumption reduce the dimension of missing data and not necessitate the knowledge of the size of the entire network -- a great advantage. Overall, the dimension reduction trick is cool and can be helpful, but I’m not sure it can be easily extended. Moreover, they did not compare it to the analysis typically done on egocentric networks (multi level regressions).},
  doi      = {10.1016/j.socnet.2017.01.001},
  file     = {ScienceDirect Snapshot:C\:\\Users\\bar21\\Zotero\\storage\\FAX6SKVW\\S0378873316302568.html:text/html;Sewell - 2017 - Network autocorrelation models with egocentric dat.pdf:C\:\\Users\\bar21\\Zotero\\storage\\7V6E3PFZ\\Sewell - 2017 - Network autocorrelation models with egocentric dat.pdf:application/pdf},
  keywords = {Bayesian estimation, Actor attributes, Social influence, Spatial autoregressive model},
  language = {en},
  url      = {https://www.sciencedirect.com/science/article/pii/S0378873316302568},
  urldate  = {2023-06-12},
}

@Misc{SaintJacques2019,
  author    = {Saint-Jacques, Guillaume and Varshney, Maneesh and Simpson, Jeremy and Xu, Ya},
  month     = mar,
  note      = {arXiv:1903.08755 [cs, stat]},
  title     = {Using {Ego}-{Clusters} to {Measure} {Network} {Effects} at {LinkedIn}},
  year      = {2019},
  abstract  = {A network effect is said to take place when a new feature not only impacts the people who receive it, but also other users of the platform, like their connections or the people who follow them. This very common phenomenon violates the fundamental assumption underpinning nearly all enterprise experimentation systems, the stable unit treatment value assumption (SUTVA). When this assumption is broken, a typical experimentation platform, which relies on Bernoulli randomization for assignment and two-sample t-test for assessment of significance, will not only fail to account for the network effect, but potentially give highly biased results. This paper outlines a simple and scalable solution to measuring network effects, using ego-network randomization, where a cluster is comprised of an "ego" (a focal individual), and her "alters" (the individuals she is immediately connected to). Our approach aims at maintaining representativity of clusters, avoiding strong modeling assumption, and significantly increasing power compared to traditional cluster-based randomization. In particular, it does not require product-specific experiment design, or high levels of investment from engineering teams, and does not require any changes to experimentation and analysis platforms, as it only requires assigning treatment an individual level. Each user either has the feature or does not, and no complex manipulation of interactions between users is needed. It focuses on measuring the one-out network effect (i.e the effect of my immediate connection's treatment on me), and gives reasonable estimates at a very low setup cost, allowing us to run such experiments dozens of times a year.},
  annote    = {They consider ego-cluster design in which egos are randomly sampled and their alters are collected. Each ego-alter forms a cluster. They interested on the effect of treating the alters on the egos (in comparison to the inverse problem common when the network is not known!). Since alters in sampled clusters can be members of different clusters, they define the loss rate {\textbackslash}alpha to be the difference of all alters in the clusters vs all alters in a cluster that are not a member of an already sampled cluster. As more egos are sampled (i.e., more clusters) {\textbackslash}alpha increases. Moreover, as {\textbackslash}alpha increases more egos are exposed to less treated alters thus there is less interference. They show that in that case there is attenuation towards the null. Suggested iterative algorithm that minimize {\textbackslash}alpha by first selecting egos with lowest degrees (assure less overlap/contamination between ego-alters clusters).},
  doi       = {10.48550/arXiv.1903.08755},
  file      = {arXiv Fulltext PDF:C\:\\Users\\bar21\\Zotero\\storage\\JVZJZNTG\\Saint-Jacques et al. - 2019 - Using Ego-Clusters to Measure Network Effects at L.pdf:application/pdf;arXiv.org Snapshot:C\:\\Users\\bar21\\Zotero\\storage\\BPVERANA\\1903.html:text/html},
  keywords  = {Computer Science - Social and Information Networks, Statistics - Applications},
  publisher = {arXiv},
  url       = {http://arxiv.org/abs/1903.08755},
  urldate   = {2023-06-13},
}

@Article{Sherman2009,
  author   = {Sherman, Susan G. and Sutcliffe, Catherine and Srirojn, Bangorn and Latkin, Carl A. and Aramratanna, Apinun and Celentano, David D.},
  journal  = {Social Science \& Medicine},
  title    = {Evaluation of a peer network intervention trial among young methamphetamine users in {Chiang} {Mai}, {Thailand}},
  year     = {2009},
  issn     = {0277-9536},
  month    = jan,
  number   = {1},
  pages    = {69--79},
  volume   = {68},
  abstract = {Since the 1990s, there has been a proliferation of methamphetamine use in Thailand, particularly among young people. Simultaneously, risky sexual behaviors among this population have increased. This study examined the effects of a peer network intervention and a life-skills intervention on methamphetamine and HIV risk behaviors among 18–25 year olds in Chiang Mai, Thailand. Between April 2005 and June 2007, we conducted a randomized behavioral trial to compare the efficacy of a peer educator, network-oriented intervention with a best practice, life-skills curriculum on methamphetamine use, sexual behaviors, and incident sexually transmitted infections (STIs). Follow-up occurred at 3-, 6-, 9-, and 12 months. Both conditions consisted of seven, 2h, small group sessions. Longitudinal analyses of the three outcomes were conducted by fitting repeated measures logistic regression models using generalized estimating equations. Participants (N=983) attended a median of six sessions, with no differences between arms. At each follow-up visit, retention was greater than 85\%. Participants were 75\% male and were a median of 19 years old. Over time, participants in both conditions showed a significant and dramatic decline in self-reported methamphetamine use (99\% at baseline vs. 53\% at 12 months, p{\textless}0.0001) and significant increase in consistent condom use (32\% baseline vs. 44\% at 12 months, p{\textless}0.0001). Incident STIs were common, with no differences between arms. Chlamydia had the highest incidence rate, 9.85/100 person years and HIV had a low incidence rate of 0.71/100 person years. Among young Thais, we found that a peer educator, network-oriented intervention was associated with reductions in methamphetamine use, increases in condom use, and reductions in incident STIs over 12 months. We also found parallel reductions with the life-skills condition. To our knowledge, this is the first such trial targeting this population. Small group interventions are an effective means of reducing methamphetamine use and sexual risk among Thai youth.},
  doi      = {10.1016/j.socscimed.2008.09.061},
  file     = {ScienceDirect Full Text PDF:C\:\\Users\\bar21\\Zotero\\storage\\K82X8KYM\\Sherman et al. - 2009 - Evaluation of a peer network intervention trial am.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\bar21\\Zotero\\storage\\NJI6XWU9\\S0277953608005157.html:text/html},
  groups   = {Applied network experiments},
  keywords = {Intervention, Thailand, Methamphetamine, Randomized behavioral trial, Sexually transmitted infections (STIs), Young people},
  language = {en},
  url      = {https://www.sciencedirect.com/science/article/pii/S0277953608005157},
  urldate  = {2023-06-19},
