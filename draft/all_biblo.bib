@Article{Lovasz2006,
  author   = {Lovász, László and Szegedy, Balázs},
  journal  = {Journal of Combinatorial Theory, Series B},
  title    = {Limits of dense graph sequences},
  year     = {2006},
  issn     = {0095-8956},
  month    = nov,
  number   = {6},
  pages    = {933--957},
  volume   = {96},
  abstract = {We show that if a sequence of dense graphs Gn has the property that for every fixed graph F, the density of copies of F in Gn tends to a limit, then there is a natural “limit object,” namely a symmetric measurable function W:[0,1]2→[0,1]. This limit object determines all the limits of subgraph densities. Conversely, every such function arises as a limit object. We also characterize graph parameters that are obtained as limits of subgraph densities by the “reflection positivity” property. Along the way we introduce a rather general model of random graphs, which seems to be interesting on its own right.},
  doi      = {10.1016/j.jctb.2006.05.002},
  file     = {ScienceDirect Full Text PDF:C\:\\Users\\bar21\\Zotero\\storage\\TVN6J254\\Lovász and Szegedy - 2006 - Limits of dense graph sequences.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\bar21\\Zotero\\storage\\N9CYFGY8\\S0095895606000517.html:text/html},
  groups   = {Network analysis},
  keywords = {Convergent graph sequence, Graph homomorphism, Limit, Quasirandom graph},
  language = {en},
  url      = {https://www.sciencedirect.com/science/article/pii/S0095895606000517},
  urldate  = {2023-03-16},
}

