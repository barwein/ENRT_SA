  file     = {Full Text PDF:C\:\\Users\\bar21\\Zotero\\storage\\XWGSIEPS\\Crawford et al. - 2019 - Interpretation of the Individual Effect Under Trea.pdf:application/pdf;Snapshot:C\:\\Users\\bar21\\Zotero\\storage\\MEV3L6ZN\\5490057.html:text/html},
  groups   = {Applied network experiments},
