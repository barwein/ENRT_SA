@Article{Newman2018,
  author   = {Newman, M. E. J.},
  journal  = {Physical Review E},
  title    = {Estimating network structure from unreliable measurements},
  year     = {2018},
  month    = dec,
  note     = {Publisher: American Physical Society},
  number   = {6},
  pages    = {062321},
  volume   = {98},
  abstract = {Most empirical studies of networks assume that the network data we are given represent a complete and accurate picture of the nodes and edges in the system of interest, but in real-world situations this is rarely the case. More often the data only specify the network structure imperfectly: Like data in essentially every other area of empirical science, network data are prone to measurement error and noise. At the same time, the data may be richer than simple network measurements, incorporating multiple measurements, weights, lengths, or strengths of edges, node or edge labels, or annotations of various kinds. Here we develop a general method for making estimates of network structure and properties using any form of network data, simple or complex, when the data are unreliable, and give example applications to a selection of social and biological networks.},
  doi      = {10.1103/PhysRevE.98.062321},
  file     = {Full Text PDF:C\:\\Users\\bar21\\Zotero\\storage\\RLWBU9KA\\Newman - 2018 - Estimating network structure from unreliable measu.pdf:application/pdf},
  url      = {https://link.aps.org/doi/10.1103/PhysRevE.98.062321},
  urldate  = {2023-03-26},
}

@Article{Young2021,
  author   = {Young, Jean-Gabriel and Cantwell, George T. and Newman, M. E. J.},
  journal  = {Journal of Complex Networks},
  title    = {Bayesian inference of network structure from unreliable data},
  year     = {2021},
  issn     = {2051-1310, 2051-1329},
  month    = mar,
  note     = {arXiv:2008.03334 [physics, stat]},
  number   = {6},
  pages    = {cnaa046},
  volume   = {8},
  abstract = {Most empirical studies of complex networks do not return direct, error-free measurements of network structure. Instead, they typically rely on indirect measurements that are often error-prone and unreliable. A fundamental problem in empirical network science is how to make the best possible estimates of network structure given such unreliable data. In this paper we describe a fully Bayesian method for reconstructing networks from observational data in any format, even when the data contain substantial measurement error and when the nature and magnitude of that error is unknown. The method is introduced through pedagogical case studies using real-world example networks, and specifically tailored to allow straightforward, computationally efficient implementation with a minimum of technical input. Computer code implementing the method is publicly available.},
  annote   = {Comment: 16 pages, 7 figures},
  doi      = {10.1093/comnet/cnaa046},
  file     = {Young et al. - 2021 - Bayesian inference of network structure from unrel.pdf:C\:\\Users\\bar21\\Zotero\\storage\\J5UKGBK9\\Young et al. - 2021 - Bayesian inference of network structure from unrel.pdf:application/pdf},
  keywords = {Computer Science - Social and Information Networks, Physics - Physics and Society, Statistics - Applications},
  language = {en},
  url      = {http://arxiv.org/abs/2008.03334},
  urldate  = {2022-08-01},
}

