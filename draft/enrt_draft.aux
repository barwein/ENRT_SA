\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Egocentric sampling. Panel~(A) shows the full $N=7$ population network. Panel~(B) illustrates an egocentric sample: each ego (dark blue, $n_e=2$) reports only a subset of its true neighborhood as alters (medium blue, $n_a=3$). The observed network is composed of disjoint ego–networks stars (solid lines), while ego–ego and unreported ego–alter connections remain latent (dashed lines). All other edges are also unobserved (dotted lines).}}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:egonetwork}{{1}{2}{Egocentric sampling. Panel~(A) shows the full $N=7$ population network. Panel~(B) illustrates an egocentric sample: each ego (dark blue, $n_e=2$) reports only a subset of its true neighborhood as alters (medium blue, $n_a=3$). The observed network is composed of disjoint ego–networks stars (solid lines), while ego–ego and unreported ego–alter connections remain latent (dashed lines). All other edges are also unobserved (dotted lines)}{figure.caption.1}{}}
\newlabel{fig:egonetwork@cref}{{[figure][1][]1}{[1][2][]2}{}{}{}}
